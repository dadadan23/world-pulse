# World Pulse - Environment Variables
# Copy this to .env.local and fill in your API keys

# OpenWeather API (required for weather data)
# Get free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# NewsAPI (required for news data)
# Get free key at: https://newsapi.org/
NEWSAPI_KEY=

# NASA API (for Near-Earth Asteroids collector)
# DEMO_KEY is used by default but has a 30 req/hour, 50 req/day limit.
# Get a free key at: https://api.nasa.gov/ (1000 req/hour)
NASA_API_KEY=

# Application Settings
NODE_ENV=development
PORT=3000

# Frontend -- URL the React renderer uses to reach the backend server.
# Override this when deploying the renderer and server on different origins.
VITE_SERVER_URL=http://localhost:3000
